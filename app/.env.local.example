ANTHROPIC_API_KEY=
ARKIV_PRIVATE_KEY=
GITHUB_TOKEN=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_ETH_PRICE_USD=3200
MOCK_MODE=0
FORCE_ROUTING=
# Required for all Claude calls (classifier + orchestrator + subagent executor)
ANTHROPIC_API_KEY=sk-ant-...

# Required for Arkiv Braga writes
# In production, store this only in Vercel project environment variables.
# Do not expose it to the browser or commit it.
ARKIV_PRIVATE_KEY=0x...

# Optional - USD display rate used in the UI.
NEXT_PUBLIC_ETH_PRICE_USD=3200

# Optional - raises GitHub rate limit from 60/hr to 5000/hr for /api/register
GITHUB_TOKEN=ghp_...

# Optional - use deterministic mock orchestration locally when no provider key is available.
# In development, the app will also auto-fallback to mock mode if ANTHROPIC_API_KEY is missing.
MOCK_MODE=0

# Optional - force classifier output for demo safety.
# Comma-separated key=tier pairs. Keys are matched substring-wise against task descriptions.
# FORCE_ROUTING=pricing=complex,landing=moderate,faq=simple
